<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Turing Agents — curator daemon (template).
  Do not edit/install this file directly. Run `scripts/install.sh --daemon`, which
  substitutes the __PLACEHOLDERS__ for this machine and installs it to
  ~/Library/LaunchAgents. The script it runs (evolve.sh) only edits framework files.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>__LABEL__</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/scripts/evolve.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>1500</integer>
    <key>RunAtLoad</key>
    <false/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__CLAUDE_DIR__:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/.claude/daemon/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/.claude/daemon/launchd.err.log</string>
</dict>
</plist>
